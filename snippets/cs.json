{
    "Unity MonoBehaviour": {
        "prefix": "MonoBehaviour",
        "description": "Unity MonoBehaviour class template.",
        "body": [
            "using UnityEngine;",
            "",
            "public class ${TM_FILENAME_BASE} : MonoBehaviour",
            "{",
            "\t$0",
            "}"
        ]
    },
    "SerializeField Variable": {
        "prefix": "sf",
        "description": "[SerializeField] private variable",
        "body": [
            "[SerializeField] private ${1:float} ${2:variableName};$0"
        ]
    },
    "SerializeField Variable with Header": {
        "prefix": "sfh",
        "description": "[SerializeField] private variable with Header",
        "body": [
            "[Header(\"${1:Header Name}\")]",
            "[SerializeField] private ${2:float} ${3:variableName};$0"
        ]
    },
    "GetComponent Call": {
        "prefix": "getcomp",
        "description": "GetComponent<Type>() call",
        "body": [
            "${1:var} = GetComponent<${2:Type}>();$0"
        ]
    },
    "TryGetComponent Call": {
        "prefix": "trygetcomp",
        "description": "if (TryGetComponent<Type>(out var component))",
        "body": [
            "if (TryGetComponent<${1:Type}>(out var ${2:comp}))",
            "{",
            "\t$0",
            "}"
        ]
    },
    "GetComponent in Awake": {
        "prefix": "getcompawake",
        "description": "Get component reference in Awake()",
        "body": [
            "private ${1:Type} _${2:varName};",
            "",
            "private void Awake()",
            "{",
            "\t_${2:varName} = GetComponent<${1:Type}>();",
            "}$0"
        ]
    },
    "Unity Coroutine": {
        "prefix": "coroutine",
        "description": "IEnumerator Coroutine method",
        "body": [
            "private System.Collections.IEnumerator ${1:CoroutineName}()",
            "{",
            "\tyield return new WaitForSeconds(${2:1f});",
            "\t$0",
            "}"
