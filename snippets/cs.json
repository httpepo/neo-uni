    "Unity Singleton": {
        "prefix": "singleton",
        "description": "Create a classic MonoBehaviour Singleton pattern",
        "body": [
            "public static ${TM_FILENAME_BASE} Instance { get; private set; }",
            "",
            "private void Awake()",
            "{",
            "\tif (Instance != null && Instance != this)",
            "\t{",
            "\t\tDestroy(gameObject);",
            "\t\treturn;",
            "\t}",
            "\tInstance = this;",
            "}$0"
        ]
    },
